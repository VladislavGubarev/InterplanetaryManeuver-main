<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Palette -->
    <Color x:Key="Color.Ink0">#0B0D10</Color>
    <Color x:Key="Color.Ink1">#10131A</Color>
    <Color x:Key="Color.Ink2">#171C26</Color>
    <Color x:Key="Color.Line">#273246</Color>
    <Color x:Key="Color.Text0">#EEF2FF</Color>
    <Color x:Key="Color.Text1">#B8C3DA</Color>
    <Color x:Key="Color.Text2">#7E8CAA</Color>
    <Color x:Key="Color.Accent">#5AE4FF</Color>
    <Color x:Key="Color.Accent2">#FFB45A</Color>
    <Color x:Key="Color.Danger">#FF5A72</Color>

    <SolidColorBrush x:Key="Brush.Ink0" Color="{StaticResource Color.Ink0}" />
    <SolidColorBrush x:Key="Brush.Ink1" Color="{StaticResource Color.Ink1}" />
    <SolidColorBrush x:Key="Brush.Ink2" Color="{StaticResource Color.Ink2}" />
    <SolidColorBrush x:Key="Brush.Line" Color="{StaticResource Color.Line}" />
    <SolidColorBrush x:Key="Brush.Text0" Color="{StaticResource Color.Text0}" />
    <SolidColorBrush x:Key="Brush.Text1" Color="{StaticResource Color.Text1}" />
    <SolidColorBrush x:Key="Brush.Text2" Color="{StaticResource Color.Text2}" />
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}" />
    <SolidColorBrush x:Key="Brush.Accent2" Color="{StaticResource Color.Accent2}" />
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}" />

    <!-- Scrollbars -->
    <Color x:Key="Color.Scroll.Track">#14273246</Color>
    <Color x:Key="Color.Scroll.Thumb">#66B8C3DA</Color>
    <Color x:Key="Color.Scroll.ThumbHover">#A05AE4FF</Color>
    <Color x:Key="Color.Scroll.ThumbDrag">#CC5AE4FF</Color>

    <SolidColorBrush x:Key="Brush.Scroll.Track" Color="{StaticResource Color.Scroll.Track}" />
    <SolidColorBrush x:Key="Brush.Scroll.Thumb" Color="{StaticResource Color.Scroll.Thumb}" />
    <SolidColorBrush x:Key="Brush.Scroll.ThumbHover" Color="{StaticResource Color.Scroll.ThumbHover}" />
    <SolidColorBrush x:Key="Brush.Scroll.ThumbDrag" Color="{StaticResource Color.Scroll.ThumbDrag}" />

    <!-- Window / panels -->
    <LinearGradientBrush x:Key="Brush.WindowBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#D90A0D12" Offset="0" />
        <GradientStop Color="#CC101725" Offset="0.55" />
        <GradientStop Color="#C407121C" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.PanelBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#321B2230" Offset="0" />
        <GradientStop Color="#24111720" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.AccentGlow" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#405AE4FF" Offset="0" />
        <GradientStop Color="#00FFFFFF" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>

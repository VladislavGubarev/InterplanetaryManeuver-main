<ui:FluentWindow x:Class="InterplanetaryManeuver.App.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:controls="clr-namespace:InterplanetaryManeuver.App.Controls"
                 mc:Ignorable="d"
                 Title="Межпланетный маневр"
                 Width="1500"
                 Height="940"
                 MinWidth="1024"
                 MinHeight="700"
                 Background="{StaticResource Brush.WindowBackground}"
                 ResizeMode="CanResize"
                 WindowBackdropType="Mica"
                 WindowCornerPreference="Round"
                 ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <LinearGradientBrush x:Key="HeroBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#D12C6876" Offset="0" />
            <GradientStop Color="#C2267B87" Offset="0.45" />
            <GradientStop Color="#BC1C3958" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="AccentLineBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8B6EF8FF" Offset="0" />
            <GradientStop Color="#73A2FF" Offset="0.55" />
            <GradientStop Color="#FFB45A" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="SurfaceCard" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="BorderBrush" Value="#213A56" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#7A101722" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="HeroCard" TargetType="{x:Type Border}" BasedOn="{StaticResource SurfaceCard}">
            <Setter Property="Background" Value="{StaticResource HeroBrush}" />
            <Setter Property="BorderBrush" Value="#4D7EA7" />
            <Setter Property="Padding" Value="26" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text0}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text2}" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="InfoChip" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="BorderBrush" Value="#34516C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#24161E29" />
        </Style>

        <Style x:Key="MetricTile" TargetType="{x:Type Border}">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="BorderBrush" Value="#2C4663" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#5C0F1620" />
        </Style>

        <Style x:Key="MonoOutputTextBox" TargetType="{x:Type TextBox}" BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontFamily" Value="{StaticResource Font.Mono}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="MinHeight" Value="180" />
        </Style>

        <Style x:Key="RailButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="MinHeight" Value="70" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text1}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                CornerRadius="20"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#40192531" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2E5172" />
                                <Setter Property="Foreground" Value="{StaticResource Brush.Text0}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#5B19385A" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#66B7F0FF" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContentOnlyTabControl" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <ContentPresenter ContentSource="SelectedContent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="VisibleWhenResultsStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasResults}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VisibleWhenNoResultsStyle" TargetType="{x:Type FrameworkElement}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasResults}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </ui:FluentWindow.Resources>

    <Grid>
        <ui:TitleBar Title="Межпланетный маневр"
                     CloseClicked="Close_Click"
                     MaximizeClicked="Maximize_Click"
                     MinimizeClicked="Minimize_Click"
                     Background="#140E141D"
                     BorderBrush="#1E324A"
                     BorderThickness="0,0,0,1"
                     ButtonsForeground="{StaticResource Brush.Text1}" />

        <Grid Margin="14,56,14,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SurfaceCard}" Padding="10,14">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,0,0,18">
                        <Border Width="54" Height="54" CornerRadius="18" Background="#66246D86" BorderBrush="#5CC9F5FF" BorderThickness="1">
                            <Viewbox Margin="14">
                                <Grid>
                                    <Ellipse Stroke="#D7F8FF" StrokeThickness="1.5" />
                                    <Ellipse Width="8" Height="8" Fill="#D7F8FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Grid>
                            </Viewbox>
                        </Border>
                        <TextBlock Text="IM" FontWeight="SemiBold" Margin="0,10,0,0" HorizontalAlignment="Center" />
                    </StackPanel>

                    <StackPanel>
                        <ToggleButton x:Name="SimulationButton" Style="{StaticResource RailButtonStyle}" Click="NavButton_Click" Tag="0" IsChecked="True">
                            <StackPanel>
                                <Grid HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Home24" FontSize="22" />
                                    <Border Background="#5CC9F5FF" CornerRadius="8" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-8,0">
                                        <TextBlock Text="1" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="Модель" Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton x:Name="OptimizationButton" Style="{StaticResource RailButtonStyle}" Click="NavButton_Click" Tag="1" IsEnabled="{Binding IsModelCalculated}"
                                      ToolTip="Сначала запустите расчёт на вкладке Модель">
                            <StackPanel>
                                <Grid HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="DataHistogram24" FontSize="22" />
                                    <Border Background="#5CC9F5FF" CornerRadius="8" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-8,0">
                                        <TextBlock Text="2" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="Поиск" Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton x:Name="AnimationButton" Style="{StaticResource RailButtonStyle}" Click="NavButton_Click" Tag="2" IsEnabled="{Binding IsModelCalculated}"
                                      ToolTip="Сначала запустите расчёт или оптимизацию">
                            <StackPanel>
                                <Grid HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Play24" FontSize="22" />
                                    <Border Background="#5CC9F5FF" CornerRadius="8" Width="16" Height="16" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-8,0">
                                        <TextBlock Text="3" FontSize="9" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <TextBlock Text="Сцена" Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>

                        <ToggleButton x:Name="SandboxButton" Style="{StaticResource RailButtonStyle}" Click="NavButton_Click" Tag="3">
                            <StackPanel>
                                <ui:SymbolIcon Symbol="Box24" HorizontalAlignment="Center" FontSize="22" />
                                <TextBlock Text="Песок" Margin="0,8,0,0" HorizontalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource HeroCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="PageHeaderTitle"
                                       Text="Симуляция"
                                       FontSize="34"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,8" />
                            <TextBlock x:Name="PageHeaderSubtitle"
                                       Text="Расчёт траекторий, метрики пролёта у Юпитера и графики состояния системы."
                                       Foreground="#E7F5FF"
                                       FontSize="14"
                                       TextWrapping="Wrap" />

                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Border Style="{StaticResource MetricTile}" Width="230">
                                <StackPanel>
                                    <TextBlock Text="Статус" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding StatusText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricTile}">
                                <StackPanel>
                                    <TextBlock Text="Эпоха" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding EpochText}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricTile}">
                                <StackPanel>
                                    <TextBlock Text="V∞" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding VInfinityKms, StringFormat={}{0:F2} км/с}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource MetricTile}">
                                <StackPanel>
                                    <TextBlock Text="Горизонт" Style="{StaticResource FieldLabel}" />
                                    <TextBlock Text="{Binding DurationDays, StringFormat={}{0:F0} суток}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </Grid>
                </Border>

                <TabControl Grid.Row="2"
                            x:Name="MainTabs"
                            Style="{StaticResource ContentOnlyTabControl}"
                            SelectedIndex="0">
                    <TabItem Header="Симуляция">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="300" MaxWidth="400" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" MinWidth="340" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Сценарий и сближение" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Настройки начальных условий для полёта: выбор пресета, эпоха, углы входа и скорость." Margin="8,0,0,14" />
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Пресет" Style="{StaticResource FieldLabel}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Готовый набор параметров сценария. Выберите подходящий пресет для быстрого старта или настройте вручную." />
                                            </StackPanel>
                                            <ComboBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}" Margin="0,0,0,14" />

                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="{x:Type StackPanel}">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIdealFlybyPreset}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Эпоха Horizons (UTC)" Style="{StaticResource FieldLabel}" />
                                                    <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Дата начала симуляции в формате UTC. Определяет положения планет по эфемеридам JPL Horizons." />
                                                </StackPanel>
                                                <TextBox Text="{Binding EpochText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                                                <Grid Margin="0,0,0,14">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="12" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Фаза входа, град" Style="{StaticResource FieldLabel}" />
                                                            <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Угол положения аппарата на сфере влияния Юпитера относительно вектора Солнце-Юпитер." />
                                                        </StackPanel>
                                                        <TextBox Text="{Binding PhaseAngleDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="Угол входа, град" Style="{StaticResource FieldLabel}" />
                                                            <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Угол между вектором скорости аппарата и направлением к центру Юпитера." />
                                                        </StackPanel>
                                                        <TextBox Text="{Binding HeadingAngleDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Гиперболическая скорость V∞, км/с" Style="{StaticResource FieldLabel}" />
                                                    <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Избыточная скорость аппарата относительно Юпитера на бесконечном удалении. Она определяет форму гиперболы пролета." />
                                                </StackPanel>
                                                <TextBox Text="{Binding VInfinityKms, UpdateSourceTrigger=PropertyChanged}" />
                                            </StackPanel>

                                            <StackPanel>
                                                <StackPanel.Style>
                                                    <Style TargetType="{x:Type StackPanel}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIdealFlybyPreset}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Стартовое расстояние r0, км" Style="{StaticResource FieldLabel}" />
                                                    <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Начальное расстояние аппарата от Юпитера в аналитической модели." />
                                                </StackPanel>
                                                <TextBox Text="{Binding IdealStartDistanceKm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Минимальный радиус пролёта R, км" Style="{StaticResource FieldLabel}" />
                                                    <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Минимальное допустимое расстояние при пролёте. Не должен быть меньше радиуса Юпитера (~71 492 км)." />
                                                </StackPanel>
                                                <TextBox Text="{Binding IdealSafeRadiusKm, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,14" />

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="Скорость Юпитера vp, км/с" Style="{StaticResource FieldLabel}" />
                                                    <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Орбитальная скорость Юпитера вокруг Солнца. Среднее значение ≈ 13.07 км/с." />
                                                </StackPanel>
                                                <TextBox Text="{Binding IdealPlanetSpeedKms, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" />

                                                <TextBlock Text="Аналитический режим строит идеальную параболическую траекторию в системе Юпитера и оценивает прирост гелиоцентрической скорости без N-body интегрирования."
                                                           Foreground="#BFD4E8"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource SurfaceCard}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsIdealFlybyPreset}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Интегратор" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Параметры численного интегрирования RK-45 (Dormand-Prince). Определяют точность и длительность расчёта." Margin="8,0,0,14" />
                                            </StackPanel>

                                            <Grid Margin="0,0,0,14">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Длительность, сутки" Style="{StaticResource FieldLabel}" />
                                                        <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Общее время симуляции в сутках. Большее значение — дольше расчёт, но полнее картина манёвра." />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding DurationDays, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="Шаг вывода, часы" Style="{StaticResource FieldLabel}" />
                                                        <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Интервал записи кадров для графиков и анимации. Меньший шаг — более плавная анимация." />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding OutputStepHours, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="12" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="AbsTol" Style="{StaticResource FieldLabel}" />
                                                        <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Абсолютный допуск ошибки. Определяет минимальную точность в единицах измеряемых величин (метры, м/с)." />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding AbsTol, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="RelTol" Style="{StaticResource FieldLabel}" />
                                                        <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Относительный допуск ошибки. Определяет точность как долю от значения величины (например, 1e-9 означает 9 знаков после запятой)." />
                                                    </StackPanel>
                                                    <TextBox Text="{Binding RelTol, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <CheckBox IsChecked="{Binding UseTensors}" VerticalAlignment="Center" />
                                                <TextBlock Text="Тензорное ускорение (SIMD)" Margin="6,0,0,0" VerticalAlignment="Center" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Использовать System.Numerics.Tensors (TensorPrimitives) для SIMD-ускорения вычисления гравитационных сил. Результат идентичен скалярному пути — ускорение заметно на большом числе тел." Margin="8,0,0,0" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Команды" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Запуск симуляции, экспорт результатов. После расчёта откроются вкладки Поиск и Сцена." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <Button Content="Запустить расчёт"
                                                    Style="{StaticResource Button.Primary}"
                                                    Command="{Binding RunCommand}"
                                                    MinHeight="48"
                                                    FontSize="14"
                                                    FontWeight="SemiBold" />
                                            <Button Content="Отмена"
                                                    Command="{Binding CancelCommand}"
                                                    Margin="0,10,0,0"
                                                    MinHeight="42" />

                                            <Separator Margin="0,16" />

                                            <Button Content="Сохранить отчёт"
                                                    Command="{Binding SaveReportCommand}"
                                                    MinHeight="42" />
                                            <Button Content="Экспорт CSV"
                                                    Command="{Binding ExportCsvCommand}"
                                                    Margin="0,10,0,0"
                                                    MinHeight="42" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Метрики" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Ключевые численные показатели результата: минимальное расстояние, прирост скорости, сохранение энергии." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <TextBox Text="{Binding MetricsText, Mode=OneWay}" Style="{StaticResource MonoOutputTextBox}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Column="2">
                                    <Border>
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}" BasedOn="{StaticResource HeroCard}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasResults}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="Сначала задайте параметры и запустите RK-45"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="После расчёта здесь появятся траектории, графики скорости и подробный отчёт по найденному решению. Так экран не перегружен на первом запуске и остаётся удобным даже на небольшом окне."
                                                       Foreground="#E7F5FF"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,18,0,0">
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="1. Проверьте эпоху и параметры сближения" FontSize="12" />
                                                </Border>
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="2. Нажмите Запустить RK-45" FontSize="12" />
                                                </Border>
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="3. Изучайте графики и отчёт" FontSize="12" />
                                                </Border>
                                            </WrapPanel>

                                            <Separator Margin="0,24,0,16" Background="#2C4663" />
                                            
                                            <TextBlock Text="Предпросмотр траектории" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                            <controls:OrbitSceneControl Height="380"
                                                                        SceneData="{Binding PreviewScene}"
                                                                        DraggableBodyIndex="{Binding PreviewSpacecraftIndex}"
                                                                        BodyDraggedCommand="{Binding PreviewBodyDraggedCommand}"
                                                                        Title="Положение аппарата и пролёт" />
                                            <TextBlock Text="* Центр координат — Юпитер. Нажмите левой кнопкой в любое место на сцене чтобы переместить аппарат и изменить параметры входа."
                                                       FontSize="11" Foreground="{StaticResource Brush.Text2}" Margin="4,8,0,0" FontStyle="Italic" />
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Style="{StaticResource VisibleWhenResultsStyle}">
                                        <controls:Plot2DControl Height="380"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding OrbitSeries}"
                                                                Title="{Binding OrbitPlotTitle}"
                                                                XLabel="{Binding OrbitPlotXLabel}"
                                                                YLabel="{Binding OrbitPlotYLabel}"
                                                                EqualAspect="True" />

                                        <controls:Plot2DControl Height="220"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding SpeedSeries}"
                                                                Title="{Binding SpeedPlotTitle}"
                                                                XLabel="{Binding SpeedPlotXLabel}"
                                                                YLabel="{Binding SpeedPlotYLabel}" />

                                        <controls:Plot2DControl Height="220"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding SpeedComponentSeries}"
                                                                Title="{Binding SpeedComponentPlotTitle}"
                                                                XLabel="{Binding SpeedComponentPlotXLabel}"
                                                                YLabel="{Binding SpeedComponentPlotYLabel}" />

                                        <controls:Plot2DControl Height="220"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding EnergySeries}"
                                                                Title="{Binding EnergyPlotTitle}"
                                                                XLabel="{Binding EnergyPlotXLabel}"
                                                                YLabel="{Binding EnergyPlotYLabel}" />

                                        <controls:Plot2DControl Height="220"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding MomentumSeries}"
                                                                Title="{Binding MomentumPlotTitle}"
                                                                XLabel="{Binding MomentumPlotXLabel}"
                                                                YLabel="{Binding MomentumPlotYLabel}" />

                                        <controls:Plot2DControl Height="220"
                                                                Margin="0,0,0,16"
                                                                Series="{Binding ConservationSeries}"
                                                                Title="{Binding ConservationPlotTitle}"
                                                                XLabel="{Binding ConservationPlotXLabel}"
                                                                YLabel="{Binding ConservationPlotYLabel}" />

                                        <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                            <StackPanel>
                                                <TextBlock Text="Отчёт по решению" Style="{StaticResource SectionTitle}" />
                                                <TextBox Text="{Binding ReportText, Mode=OneWay}" Style="{StaticResource MonoOutputTextBox}" MinHeight="220" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Оптимизация">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="300" MaxWidth="390" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" MinWidth="340" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Диапазон фазы" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Интервал фазовых углов для поиска лучшей точки входа." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <TextBlock Text="Минимум, град" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding OptPhaseMinDeg, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Максимум, град" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptPhaseMaxDeg, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Количество точек" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptPhaseSamples, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Диапазон угла входа" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Интервал углов наклона вектора скорости для перебора." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <TextBlock Text="Минимум, град" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding OptHeadingMinDeg, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Максимум, град" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptHeadingMaxDeg, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Количество точек" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptHeadingSamples, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Диапазон V∞" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Интервал скоростей на бесконечности для перебора." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <TextBlock Text="Минимум, км/с" Style="{StaticResource FieldLabel}" />
                                            <TextBox Text="{Binding OptVInfinityMinKms, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Максимум, км/с" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptVInfinityMaxKms, UpdateSourceTrigger=PropertyChanged}" />
                                            <TextBlock Text="Количество точек" Style="{StaticResource FieldLabel}" Margin="0,10,0,6" />
                                            <TextBox Text="{Binding OptVInfinitySamples, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Локальная доводка" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Градиентная оптимизация после сеточного перебора. Уточняет лучший результат малыми шагами по градиенту целевой функции." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <CheckBox Content="Включить после сеточного перебора"
                                                      IsChecked="{Binding UseLocalRefinement}"
                                                      Margin="0,0,0,12" />

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Итерации" Style="{StaticResource FieldLabel}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Максимальное число шагов градиентной оптимизации. Больше итераций — точнее результат, но дольше расчёт." />
                                            </StackPanel>
                                            <TextBox Text="{Binding LocalIterations, UpdateSourceTrigger=PropertyChanged}" />

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,6">
                                                <TextBlock Text="Порог нормы градиента" Style="{StaticResource FieldLabel}" Margin="0" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Если норма градиента меньше этого порога — оптимизация останавливается (достигнут локальный оптимум)." />
                                            </StackPanel>
                                            <TextBox Text="{Binding GradientNormTolerance, UpdateSourceTrigger=PropertyChanged}" />

                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                                                <TextBlock Text="Шаги дифференцирования" Style="{StaticResource FieldLabel}" Margin="0" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Размер приращения для численного дифференцирования целевой функции по каждому параметру." />
                                            </StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Фаза, град" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding PhaseDerivativeStepDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Угол, град" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding HeadingDerivativeStepDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="V∞, км/с" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding VInfinityDerivativeStepKms, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,12,0,6">
                                                <TextBlock Text="Шаги обновления" Style="{StaticResource FieldLabel}" Margin="0" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Максимальный размер шага коррекции параметра за одну итерацию локальной доводки." />
                                            </StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="8" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Фаза, град" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding PhaseMoveStepDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="Угол, град" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding HeadingMoveStepDeg, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="V∞, км/с" Style="{StaticResource FieldLabel}" />
                                                    <TextBox Text="{Binding VInfinityMoveStepKms, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Поиск" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Запуск полного перебора по сетке параметров. Лучший вариант берётся для доводки." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <Button Content="Подобрать траекторию"
                                                    Style="{StaticResource Button.Primary}"
                                                    Command="{Binding OptimizeCommand}"
                                                    MinHeight="48"
                                                    FontSize="14"
                                                    FontWeight="SemiBold" />
                                            <Button Content="Отмена"
                                                    Command="{Binding CancelCommand}"
                                                    Margin="0,10,0,0"
                                                    MinHeight="42" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource HeroCard}">
                                        <StackPanel>
                                            <TextBlock Text="Оптимизация гравиманёвра"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="Здесь идёт перебор траекторий по фазе, углу входа и гиперболической скорости. В результате выбирается вариант с лучшим score и максимальным полезным приростом скорости."
                                                       Foreground="#E7F5FF"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                        <StackPanel>
                                            <TextBlock Text="Ход и результаты оптимизации" Style="{StaticResource SectionTitle}" />
                                            <TextBox Text="{Binding OptimizationText, Mode=OneWay}" Style="{StaticResource MonoOutputTextBox}" MinHeight="620" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Анимация">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="300" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="Auto" MinWidth="280" MaxWidth="360" />
                            </Grid.ColumnDefinitions>

                            <controls:OrbitSceneControl Grid.Column="0"
                                                        Title="Сцена полёта"
                                                        SceneData="{Binding AnimationScene}"
                                                        FrameIndex="{Binding AnimationFrameIndex}"
                                                        ResetViewVersion="{Binding AnimationViewResetVersion}" />

                            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Border Style="{StaticResource HeroCard}">
                                    <StackPanel>
                                        <TextBlock Text="Орбитальная сцена"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="Используйте этот экран как демонстрационный режим: здесь видно движение тел по кадрам интегрирования и общий рисунок манёвра."
                                                   Foreground="#E7F5FF"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Text="Колесо мыши — зум, зажатая левая кнопка — перемещение сцены, средняя кнопка — быстрый сброс вида."
                                                   Foreground="{StaticResource Brush.Text2}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Статус пролёта" Style="{StaticResource SectionTitle}" />
                                            <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Текущее состояние пролёта: минимальное расстояние до планеты, прирост скорости и т.д." Margin="8,0,0,14" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding AnimationStatusText}"
                                                   Foreground="{StaticResource Brush.Text1}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource SurfaceCard}">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Проигрывание" Style="{StaticResource SectionTitle}" />
                                            <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Управление анимацией: пуск/пауза, скорость, покадровое перемещение по временной шкале." Margin="8,0,0,14" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding AnimationFrameLabel}" Foreground="{StaticResource Brush.Text1}" Margin="0,0,0,12" />
                                        <Slider Minimum="0"
                                                Maximum="{Binding AnimationFrameMax}"
                                                Value="{Binding AnimationFrameIndex, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Text="{Binding AnimationSpeedLabel}"
                                                   Foreground="{StaticResource Brush.Text1}"
                                                   Margin="0,16,0,8" />
                                        <Slider Minimum="0.25"
                                                Maximum="4"
                                                TickFrequency="0.25"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding AnimationSpeedMultiplier, UpdateSourceTrigger=PropertyChanged}" />

                                        <Button Content="Старт / Пауза"
                                                Style="{StaticResource Button.Primary}"
                                                Command="{Binding ToggleAnimationCommand}"
                                                Margin="0,16,0,0"
                                                MinHeight="46" />
                                        <Button Content="Сброс кадра"
                                                Command="{Binding ResetAnimationCommand}"
                                                Margin="0,10,0,0"
                                                MinHeight="42" />
                                        <Button Content="Сброс вида"
                                                Command="{Binding ResetAnimationViewCommand}"
                                                Margin="0,10,0,0"
                                                MinHeight="42" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </TabItem>
                    <TabItem Header="Песочница">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="0.9*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <Border Style="{StaticResource HeroCard}">
                                        <StackPanel>
                                            <TextBlock Text="Редактор своей системы"
                                                       FontSize="26"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="Создайте собственную систему тел, задайте массы, координаты и скорости, а затем сразу запустите RK-45 и посмотрите поведение орбит."
                                                       Foreground="#E7F5FF"
                                                       TextWrapping="Wrap" />
                                            <WrapPanel Margin="0,16,0,0">
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="Позиции: а.е." FontSize="12" />
                                                </Border>
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="Скорости: км/с" FontSize="12" />
                                                </Border>
                                                <Border Style="{StaticResource InfoChip}">
                                                    <TextBlock Text="Масса: кг" FontSize="12" />
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Набор тел" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Список тел в вашей системе. Добавьте тела с массой, координатами и скоростями для N-body симуляции." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <WrapPanel Margin="0,0,0,14">
                                                <Button Content="Добавить тело"
                                                        Style="{StaticResource Button.Primary}"
                                                        Command="{Binding AddBodyCommand}"
                                                        MinHeight="42"
                                                        Margin="0,0,10,10" />
                                                <Button Content="Сохранить JSON"
                                                        Command="{Binding SaveBodiesCommand}"
                                                        MinHeight="42"
                                                        Margin="0,0,10,10" />
                                                <Button Content="Загрузить JSON"
                                                        Command="{Binding LoadBodiesCommand}"
                                                        MinHeight="42"
                                                        Margin="0,0,10,10" />
                                            </WrapPanel>

                                            <ItemsControl ItemsSource="{Binding CustomBodies}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource SurfaceCard}" Padding="16" Margin="0,0,0,12">
                                                            <StackPanel>
                                                                <DockPanel Margin="0,0,0,14">
                                                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" />
                                                                    <Button DockPanel.Dock="Right"
                                                                            Content="Удалить"
                                                                            Command="{Binding DataContext.RemoveCustomBodyItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}"
                                                                            MinHeight="36" />
                                                                </DockPanel>

                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="12" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="12" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="12" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>

                                                                    <StackPanel>
                                                                        <TextBlock Text="Имя" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="2">
                                                                        <TextBlock Text="Масса, кг" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding Mass, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="4">
                                                                        <TextBlock Text="X, а.е." Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding XAu, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Column="6">
                                                                        <TextBlock Text="Y, а.е." Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding YAu, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Margin="0,10,0,0">
                                                                        <TextBlock Text="Z, а.е." Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding ZAu, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                                                                        <TextBlock Text="Vx, км/с" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding VxKms, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,10,0,0">
                                                                        <TextBlock Text="Vy, км/с" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding VyKms, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="1" Grid.Column="6" Margin="0,10,0,0">
                                                                        <TextBlock Text="Vz, км/с" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding VzKms, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>

                                                                    <StackPanel Grid.Row="2" Margin="0,10,0,0">
                                                                        <TextBlock Text="Радиус, км" Style="{StaticResource FieldLabel}" />
                                                                        <TextBox Text="{Binding RadiusKm, UpdateSourceTrigger=PropertyChanged}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <Border Style="{StaticResource SurfaceCard}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Запуск песочницы" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Запуск RK-45 интегрирования для вашей пользовательской системы тел. Результаты появятся ниже." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <WrapPanel Margin="0,0,0,14">
                                                <Border Style="{StaticResource MetricTile}">
                                                    <StackPanel>
                                                        <TextBlock Text="Объектов" Style="{StaticResource FieldLabel}" />
                                                        <TextBlock Text="{Binding CustomBodies.Count}" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                                <Border Style="{StaticResource MetricTile}">
                                                    <StackPanel>
                                                        <TextBlock Text="Статус" Style="{StaticResource FieldLabel}" />
                                                        <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" />
                                                    </StackPanel>
                                                </Border>
                                            </WrapPanel>

                                            <Button Content="Запустить песочницу"
                                                    Style="{StaticResource Button.Primary}"
                                                    Command="{Binding RunSandboxCommand}"
                                                    MinHeight="48"
                                                    FontWeight="SemiBold" />
                                            <Button Content="Отмена"
                                                    Command="{Binding CancelCommand}"
                                                    Margin="0,10,0,0"
                                                    MinHeight="42" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SurfaceCard}" Margin="0">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Вывод песочницы" Style="{StaticResource SectionTitle}" />
                                                <ContentControl Style="{StaticResource Icon.Info}" ToolTip="Результаты симуляции: координаты, скорости и другие метрики расчёта." Margin="8,0,0,14" />
                                            </StackPanel>
                                            <TextBox Text="{Binding SandboxText, Mode=OneWay}" Style="{StaticResource MonoOutputTextBox}" MinHeight="520" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>

